# Copy this to .env and fill in your values

# Server port
PORT=3000

# PostgreSQL
DATABASE_ABSENCE_URL=postgresql://dexa:password@localhost:5432/dexa_absence
DATABASE_LOGGING_URL=postgresql://dexa:password@localhost:5432/dexa_logging

# JWT — use a long random string, keep it secret
# Generate: openssl rand -base64 32
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Configuration
CACHE_TTL=60000
DEFAULT_PASSWORD=password

# Employee benefits
MAXIMUM_ALLOWED_LEAVES_PER_YEAR=15

# Base URL (used for internal HTTP calls)
APP_EMPLOYEE_BASE_URL=http://localhost:3000
M2M_EMPLOYEE_ID=a1b2c3d4-0000-0000-0000-000000000001
M2M_ROLE=hr
M2M_EMAIL=api.gateway@dexa.com
M2M_USER_ID=api.gateway
