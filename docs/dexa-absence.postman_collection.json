      "value": "admin@dexa.com",
      "type": "string",
      "description": "Change to match your seed data"
    },
    {
      "key": "login_password",
      "value": "password",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Set by Login"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Set by Login"
    },
    {
      "key": "employee_id",
      "value": "",
