{
  "info": {
    "name": "Dexa Absence Service",
    "_postman_id": "dexa-absence-service-smoke",
    "description": "Smoke tests for Dexa Absence Service API.\n\nRun order:\n1. Auth / Login\n2. Employee / Get My Profile\n3. Employee / List Employees (HR only)\n4. Employee / Create Employee (HR only)\n5. Employee / Update My Profile\n6. Attendance / Create Check-in or Check-out\n7. Leave Request / Create Leave Request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has token and user', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body).to.have.property('user');",
                  "    pm.expect(body.user).to.have.property('employeeId');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token',       body.token);",
                  "pm.collectionVariables.set('user_id',     body.user.id);",
                  "pm.collectionVariables.set('employee_id', body.user.employeeId);",
                  "pm.collectionVariables.set('email',       body.user.email);",
                  "pm.collectionVariables.set('role',        body.user.role);",
                  "",
                  "console.log('Logged in as', body.user.email, '|', body.user.role);",
                  "console.log('employee_id ->', body.user.employeeId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Stores token, user_id, employee_id, email, role into collection variables."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has message', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('message');",
                  "});",
                  "",
                  "pm.collectionVariables.unset('token');",
                  "pm.collectionVariables.unset('user_id');",
                  "pm.collectionVariables.unset('employee_id');",
                  "pm.collectionVariables.unset('email');",
                  "pm.collectionVariables.unset('role');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Employee",
      "item": [
        {
          "name": "Get My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has employee fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('email');",
                  "    pm.expect(body).to.have.property('position');",
                  "});",
                  "",
                  "pm.test('returned id matches stored employee_id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.eql(pm.collectionVariables.get('employee_id'));",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('employee_name',     body.name);",
                  "pm.collectionVariables.set('employee_position', body.position);",
                  "console.log('Profile:', body.name, '|', body.position);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}"]
            },
            "description": "Requires: token, employee_id (set by Login)."
          }
        },
        {
          "name": "List Employees (HR only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has data array and meta', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('data').that.is.an('array');",
                  "    pm.expect(body).to.have.property('meta');",
                  "    pm.expect(body.meta).to.have.all.keys(",
                  "        'page', 'limit', 'totalItems', 'totalPages', 'hasNextPage', 'hasPrevPage'",
                  "    );",
                  "});",
                  "",
                  "pm.test('each employee has required fields', function () {",
                  "    const body = pm.response.json();",
                  "    body.data.forEach(function (emp) {",
                  "        pm.expect(emp).to.have.property('id');",
                  "        pm.expect(emp).to.have.property('name');",
                  "        pm.expect(emp).to.have.property('email');",
                  "    });",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "console.log('Total employees:', body.meta.totalItems);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["employees"],
              "query": [
                { "key": "page",  "value": "1"  },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "HR only. Returns 403 if logged in as employee role."
          }
        },
        {
          "name": "Create Employee (HR only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('response has new employee fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('name');",
                  "    pm.expect(body).to.have.property('email');",
                  "    pm.expect(body).to.have.property('position');",
                  "    pm.expect(body).to.have.property('departmentId');",
                  "    pm.expect(body.isDeleted).to.eql(false);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('created_employee_id', body.id);",
                  "console.log('Created employee id ->', body.id, '|', body.name);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Jane Smith\",\n  \"email\": \"jane.smith@dexa.com\",\n  \"displayName\": \"Jane Smith\",\n  \"position\": \"Product Manager\",\n  \"departmentId\": \"IT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees",
              "host": ["{{base_url}}"],
              "path": ["employees"]
            },
            "description": "HR only. Creates a new user + employee record.\n\nRequired fields: username, email, displayName, position, departmentId.\ndepartmentId must be one of: HR, IT, FINANCE, MARKETING, SALES.\n\nStores created_employee_id into collection variables."
          }
        },
        {
          "name": "Update My Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response has updated employee fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('phoneNumber');",
                  "});",
                  "",
                  "pm.test('id matches stored employee_id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.id).to.eql(pm.collectionVariables.get('employee_id'));",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "console.log('Updated phone ->', body.phoneNumber);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"081234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}"]
            },
            "description": "Own account only. Accepts phoneNumber and/or profilePic — at least one required.\n\nRequires: token, employee_id (set by Login)."
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Create Check-in or Check-out",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// date must be exactly today — compute and inject it",
                  "const now   = new Date();",
                  "const yyyy  = now.getFullYear();",
                  "const mm    = String(now.getMonth() + 1).padStart(2, '0');",
                  "const dd    = String(now.getDate()).padStart(2, '0');",
                  "pm.collectionVariables.set('today', `${yyyy}-${mm}-${dd}`);",
                  "console.log('today ->', pm.collectionVariables.get('today'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('response has absence fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('employeeId');",
                  "    pm.expect(body).to.have.property('date');",
                  "});",
                  "",
                  "pm.test('employeeId matches stored employee_id', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.employeeId).to.eql(pm.collectionVariables.get('employee_id'));",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('absence_id', body.id);",
                  "console.log('Absence id ->', body.id, '| date ->', body.date, '| checkIn ->', body.checkInTime);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{today}}\",\n  \"checkInTime\": \"08:30\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/absences",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "absences"]
            },
            "description": "Records a daily check-in or check-out. No `type` field — that distinguishes it from a leave request.\n\ndate is auto-set to today by the pre-request script (validation rejects anything other than today).\nAt least one of checkInTime or checkOutTime is required. Format: HH:mm or HH:mm:ss.\ncheckInTime must be before checkOutTime if both are provided.\n\nStores absence_id into collection variables."
          }
        },
        {
          "name": "Get My Absences",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('response is an array', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "console.log('Absences count ->', body.length);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/absences",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "absences"]
            },
            "description": "Returns all absences for the stored employee. Optional query: startDate, endDate (yyyy-mm-dd)."
          }
        }
      ]
    },
    {
      "name": "Leave Request",
      "item": [
        {
          "name": "Create Leave Request",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// startDate and endDate must be after today",
                  "const tomorrow       = new Date();",
                  "tomorrow.setDate(tomorrow.getDate() + 1);",
                  "const dayAfter       = new Date();",
                  "dayAfter.setDate(dayAfter.getDate() + 3);",
                  "",
                  "function fmt(d) {",
                  "    const yyyy = d.getFullYear();",
                  "    const mm   = String(d.getMonth() + 1).padStart(2, '0');",
                  "    const dd   = String(d.getDate()).padStart(2, '0');",
                  "    return `${yyyy}-${mm}-${dd}`;",
                  "}",
                  "",
                  "pm.collectionVariables.set('leave_start_date', fmt(tomorrow));",
                  "pm.collectionVariables.set('leave_end_date',   fmt(dayAfter));",
                  "console.log('leave period ->', fmt(tomorrow), '->', fmt(dayAfter));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('response has leave request fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('employeeId');",
                  "    pm.expect(body).to.have.property('leaveRequest');",
                  "    pm.expect(body.leaveRequest).to.have.property('type');",
                  "    pm.expect(body.leaveRequest).to.have.property('status');",
                  "    pm.expect(body.leaveRequest).to.have.property('startDate');",
                  "    pm.expect(body.leaveRequest).to.have.property('endDate');",
                  "});",
                  "",
                  "pm.test('leave status is pending', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.leaveRequest.status).to.eql('pending');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('leave_absence_id',   body.id);",
                  "pm.collectionVariables.set('leave_request_id',   body.leaveRequest.id);",
                  "console.log('Leave request id ->', body.leaveRequest.id, '| type ->', body.leaveRequest.type, '| status ->', body.leaveRequest.status);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"sick\",\n  \"startDate\": \"{{leave_start_date}}\",\n  \"endDate\": \"{{leave_end_date}}\",\n  \"notes\": \"Fever, will rest at home\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/absences",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "absences"]
            },
            "description": "Submits a leave request. Presence of the `type` field distinguishes this from a check-in/out.\n\ntype: sick | wfh | annual_leave\nstartDate / endDate: yyyy-mm-dd, must be after today (auto-set by pre-request script).\nStatus will be pending until HR approves or rejects.\n\nStores leave_request_id and leave_absence_id into collection variables."
          }
        },
        {
          "name": "Create Leave Request — WFH",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const start = new Date();",
                  "start.setDate(start.getDate() + 1);",
                  "const end = new Date();",
                  "end.setDate(end.getDate() + 2);",
                  "",
                  "function fmt(d) {",
                  "    const yyyy = d.getFullYear();",
                  "    const mm   = String(d.getMonth() + 1).padStart(2, '0');",
                  "    const dd   = String(d.getDate()).padStart(2, '0');",
                  "    return `${yyyy}-${mm}-${dd}`;",
                  "}",
                  "",
                  "pm.collectionVariables.set('leave_start_date', fmt(start));",
                  "pm.collectionVariables.set('leave_end_date',   fmt(end));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('leave type is wfh', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.leaveRequest.type).to.eql('wfh');",
                  "});",
                  "",
                  "pm.test('leave status is pending', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.leaveRequest.status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"wfh\",\n  \"startDate\": \"{{leave_start_date}}\",\n  \"endDate\": \"{{leave_end_date}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/absences",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "absences"]
            }
          }
        },
        {
          "name": "Create Leave Request — Annual Leave",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const start = new Date();",
                  "start.setDate(start.getDate() + 7);",
                  "const end = new Date();",
                  "end.setDate(end.getDate() + 11);",
                  "",
                  "function fmt(d) {",
                  "    const yyyy = d.getFullYear();",
                  "    const mm   = String(d.getMonth() + 1).padStart(2, '0');",
                  "    const dd   = String(d.getDate()).padStart(2, '0');",
                  "    return `${yyyy}-${mm}-${dd}`;",
                  "}",
                  "",
                  "pm.collectionVariables.set('leave_start_date', fmt(start));",
                  "pm.collectionVariables.set('leave_end_date',   fmt(end));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('leave type is annual_leave', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.leaveRequest.type).to.eql('annual_leave');",
                  "});",
                  "",
                  "pm.test('leave status is pending', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.leaveRequest.status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"annual_leave\",\n  \"startDate\": \"{{leave_start_date}}\",\n  \"endDate\": \"{{leave_end_date}}\",\n  \"notes\": \"Family vacation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/absences",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "absences"]
            }
          }
        }
      ]
    }
  ],
