{
  "name": "dexa-absence-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--stack-trace-limit=50' nodemon",
    "build": "next build",
    "start": "NODE_NO_WARNINGS=1 NODE_OPTIONS='--stack-trace-limit=50' NODE_ENV=production ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' server.ts",
    "db:setup": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/setup-db.ts",
    "db:drop": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/drop-db.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:init": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/init-data.ts",
    "db:init:admin": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/init-admin-data.ts",
    "db:init:employee": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/init-employee.ts",
    "db:init:hr": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/init-hr-employee.ts",
    "db:init:m2m": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/init-m2m-employee.ts",
    "db:migrate:logging": "prisma migrate dev --schema=prisma/logging-schema.prisma",
    "db:generate:logging": "prisma generate --schema=prisma/logging-schema.prisma",
    "db:studio:logging": "prisma studio --schema=prisma/logging-schema.prisma",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/swagger-ui-react": "^5.18.0",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.3",
    "pg": "^8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swagger-ui-react": "^5.32.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.14.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
